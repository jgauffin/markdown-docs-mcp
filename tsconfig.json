{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true
  },
  // "include": ["src/**/*"],
  // "exclude": ["node_modules", "dist"]
   "include": ["src/index.ts", "src/handlers.ts", "src/source.ts"],
  "exclude":  [
    "node_modules",
    "dist",
    "build",
    ".vite",
    ".next",
    "coverage",
    "**/*.generated.*"
  ]
}